# ── LLM providers ─────────────────────────────────────────────────
# Google Gemini (fast, cloud) — get key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=<your-google-api-key>

# Ollama (local, free) — default model used when no model is specified
OLLAMA_MODEL=qwen3.5
OLLAMA_BASE_URL=http://localhost:11434

# Anthropic (optional, not used by default)
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# ── PostgreSQL + pgvector ─────────────────────────────────────────
# Must match the host port published by Docker (default 15432 — change both if "port already allocated").
POSTGRES_PORT_PUBLISH=15432
DATABASE_URL=postgresql://risk:riskpass@localhost:15432/riskanalysis

# PPO source ranking — auto-loads data/ppo_source_policy.pt if it exists (after just ppo-ensure / ppo-train).
# PPO_DISABLED=1
# PPO_SOURCE_POLICY_PATH=/custom/path.pt
# PPO_SCORE_DELTA=0.1

# ── Redis (LangGraph state checkpointing) ────────────────────────
REDIS_URL=redis://localhost:6379

# ── Observability ─────────────────────────────────────────────────

# Langfuse — self-hosted LLM observability (open-source, runs locally)
# Setup: docker compose up langfuse → http://localhost:3001 → create project → copy keys
LANGFUSE_PUBLIC_KEY=<pk-lf-your-public-key>
LANGFUSE_SECRET_KEY=<sk-lf-your-secret-key>
LANGFUSE_HOST=http://localhost:3001

# LangSmith — LangChain native tracing (cloud, traces LangGraph graph natively)
# Setup: https://smith.langchain.com → Settings → API Keys → Create
# Set LANGCHAIN_TRACING_V2=true to enable (false = disabled, no data sent)
LANGCHAIN_TRACING_V2=false
LANGSMITH_API_KEY=<lsv2_pt_your-langsmith-key>
LANGSMITH_PROJECT=RiskAnalysis
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
